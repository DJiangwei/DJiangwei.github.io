{
  "name": "east-meridian-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open /app.html",
    "build": "tsc && vite build && node scripts/finalize-build.mjs && node scripts/sync-pages-root.mjs",
    "preview": "vite preview",
    "source:add": "node scripts/add-source.mjs",
    "sources:sync": "node scripts/sync-sources.mjs",
    "sources:summarize": "node scripts/summarize-sources.mjs",
    "sources:refresh": "node scripts/sync-sources.mjs && node scripts/summarize-sources.mjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}
